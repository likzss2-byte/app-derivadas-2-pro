<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="app_derivadas_2_pro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:app_derivadas_2_pro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Analizador de Funciones Pro">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Padding="30" Spacing="15">
            <TextBlock Text="Calculadora" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="Función de Grado 3" FontWeight="SemiBold"/>
            <TextBox x:Name="InputFuncion" 
                     PlaceholderText="Ej: 4, -6, 2, -1" 
                     Header="Escribe coeficientes (a, b, c, d):"/>

            <Button x:Name="BtnCalcular" 
                    Content="Calcular Análisis" 
                    Click="OnCalcularClick" 
                    Background="#005FB8" Foreground="White"
                    HorizontalAlignment="Stretch" 
                    Height="40"/>

            <Rectangle Height="1" Fill="LightGray" Margin="0,10"/>

            <ScrollViewer>
                <StackPanel Spacing="12">
                    <TextBlock Text="Resultados del Análisis" FontWeight="SemiBold" FontSize="18"/>

                    <InfoBar IsOpen="True" IsClosable="False" Title="Derivada Primera:" x:Name="BarDerivada" Message="---" Severity="Informational" />

                    <InfoBar IsOpen="True" IsClosable="False" Title="Teorema de Rolle:" x:Name="BarRolle" Message="---" Severity="Success" />

                    <InfoBar IsOpen="True" IsClosable="False" Title="Concavidad:" x:Name="BarConcavidad" Message="---" />

                    <InfoBar IsOpen="True" IsClosable="False" Title="Punto de Inflexión:" x:Name="BarInflexion" Message="---" />

                    <InfoBar IsOpen="True" IsClosable="False" Title="Máx/Mín:" x:Name="BarExtremos" Message="---" />
                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <Border Grid.Column="1" 
                Margin="20" 
                Background="#F3F3F3" 
                CornerRadius="12" 
                BorderThickness="1" 
                BorderBrush="LightGray">

            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <SymbolIcon Symbol="Calculator" RenderTransformOrigin="0.5,0.5">
                        <SymbolIcon.RenderTransform>
                            <ScaleTransform ScaleX="2" ScaleY="2"/>
                        </SymbolIcon.RenderTransform>
                    </SymbolIcon>
                    <TextBlock Text="El gráfico se generará al calcular" Foreground="#555555"/>
                </StackPanel>

                <Canvas x:Name="CanvasGrafica"/>
            </Grid>
        </Border>
    </Grid>
</Window>